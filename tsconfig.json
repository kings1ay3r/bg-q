{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2017",
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "types": [
      "node"
    ],
    "lib": [
      "ES2017"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/__tests__"
  ]
}